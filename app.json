{
  "expo": {
    "name": "GigPay",
    "slug": "gigipay",
    "scheme": "gigipay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gigipay.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "package": "com.gigipay.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "GigPay ko aapki kamai screenshot ki photo lene ke liye camera chahiye."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GigPay ko aapki gallery se earnings screenshot select karne ki zaroorat hai."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "GigPay Voice Assistant ko aapka sawaal sunne ke liye microphone chahiye."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a063834-3967-4f7d-82d2-f9d70b5a71c8"
      }
    }
  }
}
